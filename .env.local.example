# Supabase — from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# anon/public key — used client-side ONLY for Realtime Broadcast (live cursors).
# RLS still blocks it from any table access. Required for cursors to work.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# App gate — two roles.
# Editors (Vignesh, Mrunal, Samyukta) get edit access with this password:
APP_PASSWORD=change-me-editor-password
# Everyone else logs in as a view-only guest with this password:
APP_GUEST_PASSWORD=change-me-guest-password
# One random string per role — session cookie value, distinguishes role
# unforgeably. Generate each with: openssl rand -hex 32
APP_SESSION_SECRET=replace-with-openssl-rand-hex-32
APP_GUEST_SESSION_SECRET=replace-with-a-different-openssl-rand-hex-32
