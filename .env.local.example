# Supabase — from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# anon/public key — used client-side ONLY for Realtime Broadcast (live cursors).
# RLS still blocks it from any table access. Required for cursors to work.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# App gate
APP_PASSWORD=change-me-to-a-shared-password
# Long random string — session cookie value. Generate: openssl rand -hex 32
APP_SESSION_SECRET=replace-with-openssl-rand-hex-32
